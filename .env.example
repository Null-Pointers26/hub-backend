APP_ENV=production

# FQDN for Let's Encrypt certificate
DOMAIN=example.com

# Email for certificate registration and expiry notices
CERT_EMAIL=admin@example.com

# Backend cert cache location in container
CERT_CACHE_DIR=/certs

# Frontend target for reverse proxy
FRONTEND_TARGET=http://frontend:3000

# Optional listen addresses
DEV_LISTEN_ADDR=:8080
HTTP_ADDR=:80
HTTPS_ADDR=:443
